# --- Inference (Nebius Token Factory / AI Studio) ---
NEBIUS_API_KEY=XXX

# --- MLflow tracking ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=swe-bench-agent-eval

# --- Object storage: local MinIO (default) or any S3-compatible endpoint ---
# These double as the MinIO root credentials created by scripts/start-minio.sh.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=mlops-agent-eval-runs
