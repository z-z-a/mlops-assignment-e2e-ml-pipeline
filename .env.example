# --- Inference (Nebius Token Factory / AI Studio) ---
NEBIUS_API_KEY=XXX

# --- MLflow tracking ---
# Standalone mode: http://localhost:5000. In docker compose the DAG is given
# http://mlflow:5000 automatically (see docker-compose.yaml).
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=swe-bench-agent-eval

# --- Object storage: local MinIO (default) or any S3-compatible endpoint ---
# These double as the MinIO root credentials.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=mlops-agent-eval-runs

# --- Docker Compose deployment (Phase 3) ---
# Host user/group ids so files created in containers stay accessible:
#   echo "AIRFLOW_UID=$(id -u)" >> .env
#   echo "DOCKER_GID=$(getent group docker | cut -d: -f3)" >> .env
AIRFLOW_UID=1000
DOCKER_GID=999
# Absolute path of this project on the VM (DockerOperator bind-mount source):
HOST_PROJECT_DIR=/home/zza/hw3/mlops-assignment-e2e-ml-pipeline
# Image built from the project Dockerfile: docker build -t agent-eval:latest .
AGENT_IMAGE=agent-eval:latest
# Airflow UI credentials created by airflow-init:
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
# MLflow server image — must match/exceed the mlflow version that created
# ./mlflow-data/mlflow.db (check: uv run mlflow --version):
MLFLOW_IMAGE=ghcr.io/mlflow/mlflow:v3.14.0
